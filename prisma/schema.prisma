// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum OrderStatus {
  draft
  aguardando_pagamento
  pago
  cancelado
}

enum ProductKind {
  simples
  variacoes
}

enum CouponDiscountType {
  percentual
  valor_fixo
  frete_gratis
}

enum CouponAppliesTo {
  toda_loja
  categoria
  produto
}

enum BannerPosition {
  hero_slide
  home_middle
  home_bottom
}

model User {
  id              String    @id @default(uuid())
  name            String?   @map("nome")
  email           String    @unique
  emailVerified   DateTime?
  image           String?
  senhaHash       String?
  telefone        String?
  aceitaMarketing Boolean   @default(false)
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  accounts          Account[]
  sessions          Session[]
  orders            Order[]
  addresses         Address[]
  couponRedemptions CouponRedemption[]
}

model Account {
  id                String  @id @default(uuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
}

model Session {
  id           String   @id @default(uuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model VerificationToken {
  identifier String
  token      String
  expires    DateTime

  @@unique([identifier, token])
}

model Address {
  id          String  @id @default(uuid())
  userId      String
  user        User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  apelido     String?
  cep         String
  logradouro  String
  numero      String
  complemento String?
  bairro      String
  cidade      String
  uf          String
  padrao      Boolean @default(false)

  @@index([userId])
}

// ── Catálogo ──────────────────────────────────────────────────────────────
// Sem controle de estoque: todo produto/variante cadastrado é sempre
// considerado disponível para compra (decisão de produto, não é bug).
model Product {
  id               String      @id @default(uuid())
  slug             String      @unique
  categoria        String
  nome             String
  subtitulo        String
  descricao        String
  imagem           String
  imagens          String[]
  videos           String[]    @default([])
  caracteristicas  String[]
  linkShopee       String?
  linkMercadoLivre String?
  linkTiktokShop   String?
  linkShein        String?
  ativo            Boolean     @default(true)
  tipo             ProductKind @default(simples)
  categoryId       String?
  category         Category?   @relation(fields: [categoryId], references: [id], onDelete: SetNull)

  // Avaliação/comentários digitados manualmente no admin do Hub — não é um
  // sistema de avaliação de cliente real (decisão de produto, ver skill).
  avaliacaoMedia  Float?
  totalAvaliacoes Int    @default(0)
  comentarios     Json? // [{ autor, nota, comentario, data }]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  variantes ProductVariant[]

  @@index([categoria])
  @@index([categoryId])
}

model Category {
  id            String     @id @default(uuid())
  nome          String
  slug          String     @unique
  descricao     String?
  imagemUrl     String?
  destaque      Boolean    @default(false)
  metaTitulo    String?
  metaDescricao String?
  parentId      String?
  parent        Category?  @relation("CategoryHierarchy", fields: [parentId], references: [id], onDelete: Restrict)
  children      Category[] @relation("CategoryHierarchy")
  ativo         Boolean    @default(true)
  ordem         Int        @default(0)
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt

  produtos Product[]

  @@index([parentId, ordem])
}

model ProductVariant {
  id         String  @id @default(uuid())
  productId  String
  product    Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  label      String
  precoDe    Decimal @db.Decimal(10, 2)
  precoPor   Decimal @db.Decimal(10, 2)
  skuInterno String?
  linkShopee String?

  // Frete (Melhor Envio) — sem peso/dimensão cadastrado por produto ainda;
  // defaults de pacote pequeno genérico, editável depois produto a produto.
  pesoKg        Float @default(0.3)
  alturaCm      Float @default(4)
  larguraCm     Float @default(16)
  comprimentoCm Float @default(11)

  orderItems OrderItem[]

  @@index([productId])
}

// ── Pedidos ───────────────────────────────────────────────────────────────
// Order também representa o carrinho (status "draft"), vinculado a uma
// sessão anônima via cookie. Ao finalizar, pode ser associado a um usuário;
// userId permanece nulo no checkout como convidado.
model Order {
  id                             String      @id @default(uuid())
  status                         OrderStatus @default(draft)
  sessionId                      String?     @unique
  userId                         String?
  user                           User?       @relation(fields: [userId], references: [id], onDelete: SetNull)
  nomeCliente                    String?
  emailCliente                   String?
  telefoneCliente                String?
  cpfCnpj                        String?
  cepDestino                     String?
  logradouro                     String?
  numero                         String?
  complemento                    String?
  bairro                         String?
  cidade                         String?
  uf                             String?
  subtotal                       Decimal     @default(0) @db.Decimal(10, 2)
  valorFrete                     Decimal     @default(0) @db.Decimal(10, 2)
  descontoCupom                  Decimal     @default(0) @db.Decimal(10, 2)
  total                          Decimal     @default(0) @db.Decimal(10, 2)
  couponId                       String?
  shippingQuoteId                String?     @unique
  shippingOptionId               String?
  mercadoPagoPreferenceId        String?     @unique
  mercadoPagoInitPoint           String?
  mercadoPagoPreferenceExpiresAt DateTime?
  mercadoPagoPaymentId           String?     @unique
  mercadoPagoPaymentStatus       String?
  pagoEm                         DateTime?
  createdAt                      DateTime    @default(now())

  items                 OrderItem[]
  shippingQuote         CheckoutShippingQuote? @relation("CartShippingQuote")
  selectedShippingQuote CheckoutShippingQuote? @relation("SelectedShippingQuote", fields: [shippingQuoteId], references: [id], onDelete: SetNull)
  couponRedemption      CouponRedemption?
  coupon                Coupon?                @relation(fields: [couponId], references: [id], onDelete: SetNull)
  shipment              Shipment?

  @@index([userId])
  @@index([couponId])
}

model Coupon {
  id                  String             @id @default(uuid())
  codigo              String             @unique
  descricao           String?
  tipo                CouponDiscountType
  valor               Decimal?           @db.Decimal(10, 2) // null quando tipo = frete_gratis
  valorMinimoPedido   Decimal?           @db.Decimal(10, 2)
  descontoMaximo      Decimal?           @db.Decimal(10, 2)
  limiteUsoTotal      Int?
  limiteUsoPorCliente Int                @default(1)
  usos                Int                @default(0)
  aplicaEm            CouponAppliesTo    @default(toda_loja)
  categoriaId         String? // referência quando aplicaEm = categoria (sem FK por ora — fase 2)
  produtoId           String? // referência quando aplicaEm = produto (sem FK por ora — fase 2)
  combinavel          Boolean            @default(false)
  exibirNoSite        Boolean            @default(false)
  primeiraCompra      Boolean            @default(false)
  inicioEm            DateTime?
  expiraEm            DateTime?
  ativo               Boolean            @default(true)
  createdAt           DateTime           @default(now())
  updatedAt           DateTime           @updatedAt

  redemptions CouponRedemption[]
  orders      Order[]

  @@index([ativo, inicioEm, expiraEm])
}

model CouponRedemption {
  id            String   @id @default(uuid())
  couponId      String
  coupon        Coupon   @relation(fields: [couponId], references: [id], onDelete: Cascade)
  userId        String?
  user          User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  orderId       String   @unique
  order         Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  customerKey   String
  valorDesconto Decimal  @db.Decimal(10, 2)
  createdAt     DateTime @default(now())

  @@index([couponId, customerKey])
  @@index([userId])
}

model Banner {
  id        String         @id @default(uuid())
  nome      String
  imagemUrl String
  altText   String
  linkUrl   String?
  posicao   BannerPosition
  largura   Int
  altura    Int
  ordem     Int            @default(0)
  ativo     Boolean        @default(true)
  inicioEm  DateTime?
  expiraEm  DateTime?
  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt

  @@index([posicao, ativo, ordem])
}

model StoreSettings {
  id                String   @id @default("singleton")
  nomeLoja          String   @default("EcomZero")
  descricaoFooter   String   @default("Produtos inteligentes, úteis e de qualidade para transformar sua rotina.")
  mensagemFooter    String   @default("Produtos úteis para facilitar o seu dia a dia.")
  barraAnuncioAtiva Boolean  @default(false)
  barraAnuncioTexto String?
  barraAnuncioLink  String?
  emailSuporte      String?
  telefoneSuporte   String?
  whatsapp          String?
  linkShopee        String?
  linkInstagram     String?
  linkFacebook      String?
  linkTiktok        String?
  logoUrl           String   @default("/images/logo2.png")
  faviconUrl        String?
  corPrincipal      String   @default("#A9EC17")
  fusoHorario       String   @default("America/Sao_Paulo")
  lojaAtiva         Boolean  @default(true)
  plano             String   @default("Profissional")
  moeda             String   @default("BRL")
  idioma            String   @default("pt-BR")
  updatedAt         DateTime @updatedAt
}

model OrderItem {
  id            String         @id @default(uuid())
  orderId       String
  order         Order          @relation(fields: [orderId], references: [id], onDelete: Cascade)
  variantId     String
  variant       ProductVariant @relation(fields: [variantId], references: [id])
  quantidade    Int
  precoUnitario Decimal        @db.Decimal(10, 2)

  @@unique([orderId, variantId])
  @@index([orderId])
  @@index([variantId])
}

// ── Frete (Melhor Envio) ─────────────────────────────────────────────────
// Cache curto e rate limit da rota POST /api/shipping/quote — em Postgres
// (não em memória) porque roda em funções serverless sem estado compartilhado
// entre instâncias.
model ShippingQuoteCache {
  id        String   @id @default(uuid())
  cacheKey  String   @unique // `${variantId}:${cep}`
  options   Json
  expiresAt DateTime

  @@index([expiresAt])
}

model ShippingRateLimit {
  id          String   @id @default(uuid())
  identifier  String   @unique // IP do cliente
  count       Int      @default(1)
  windowStart DateTime @default(now())

  @@index([windowStart])
}

model CheckoutShippingQuote {
  id              String   @id @default(uuid())
  orderId         String   @unique
  order           Order    @relation("CartShippingQuote", fields: [orderId], references: [id], onDelete: Cascade)
  selectedByOrder Order?   @relation("SelectedShippingQuote")
  cep             String
  options         Json
  createdAt       DateTime @default(now())
  expiresAt       DateTime

  @@index([expiresAt])
}

// Credencial OAuth de PRODUÇÃO do Melhor Envio. Singleton (id fixo "singleton"):
// só existe uma conta conectada. Access token expira em ~30 dias e é renovado
// sozinho via refresh_token (ver melhorEnvioAuthService.getValidAccessToken).
// Fica no banco, não em env var, porque o valor muda a cada refresh e precisa
// persistir entre execuções. Sandbox continua usando MELHOR_ENVIO_TOKEN fixo.
model MelhorEnvioCredential {
  id           String   @id @default("singleton")
  accessToken  String
  refreshToken String
  expiraEm     DateTime
  atualizadoEm DateTime @updatedAt
}

model ShippingSettings {
  id                 String   @id @default("singleton")
  nomeRemetente      String
  emailRemetente     String
  telefoneRemetente  String
  cpfCnpjRemetente   String
  inscricaoEstadual  String?
  atividadeEconomica String?
  cepOrigem          String
  logradouroOrigem   String
  numeroOrigem       String
  complementoOrigem  String?
  bairroOrigem       String
  cidadeOrigem       String
  ufOrigem           String
  updatedAt          DateTime @updatedAt
}

model Shipment {
  id                  String    @id @default(uuid())
  orderId             String    @unique
  order               Order     @relation(fields: [orderId], references: [id], onDelete: Cascade)
  melhorEnvioId       String?   @unique
  melhorEnvioProtocol String?
  status              String    @default("creating")
  transportadora      String?
  servico             String?
  codigoRastreio      String?
  urlRastreio         String?
  urlEtiqueta         String?
  tipoDocumentoFiscal String?
  chaveNotaFiscal     String?
  ultimoErro          String?
  compradoEm          DateTime?
  geradoEm            DateTime?
  postadoEm           DateTime?
  entregueEm          DateTime?
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  @@index([status])
}

// Usuário do painel administrativo (apps/admin). Single-user, separado do
// `User` de cliente da loja. Criado via apps/admin/scripts/create-admin.ts
// (bcrypt). Mora neste schema (o da loja) porque o admin compartilha o mesmo
// banco Postgres e NUNCA roda migração própria — toda mudança de schema nasce
// aqui, no projeto raiz, e o admin só espelha o model + `prisma generate`.
model AdminUser {
  id        String   @id @default(uuid())
  email     String   @unique
  senhaHash String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
