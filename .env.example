# Copie para .env (dev local) — nunca commitar valores reais.

# Connection string usada pela aplicação em runtime (Next.js / Vercel Functions).
# Dev local: aponta direto pro Postgres local, sem pooling.
# Produção (Vercel Postgres/Neon/Supabase): use a URL POOLED (com pgbouncer/pooler)
# — é a que o dashboard costuma chamar de DATABASE_URL, POSTGRES_URL ou POSTGRES_PRISMA_URL.
# Formato: postgresql://usuario:senha@host:porta/banco?schema=public
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/ecomzero?schema=public"

# Connection string DIRETA (sem pooler) — usada só para rodar migrações
# (`prisma migrate deploy`) e o seed. Provedores com connection pooling
# (Neon, Supabase, PgBouncer) expõem essa URL separada porque DDL/advisory
# locks não são confiáveis atrás de um pooler em modo transaction.
# Em dev local, pode ser igual à DATABASE_URL (não há pooler).
# Formato: postgresql://usuario:senha@host:porta/banco?schema=public
DIRECT_URL="postgresql://postgres:postgres@localhost:5432/ecomzero?schema=public"

# Auth.js — segredo usado para criptografar os tokens JWT da sessão.
# Gere um valor próprio com: openssl rand -base64 32
AUTH_SECRET=""

# URL pública usada para montar links enviados por e-mail.
NEXT_PUBLIC_STOREFRONT_URL="http://localhost:3000"

# E-mails transacionais da loja: cadastro, senha e ciclo do pedido (Resend).
# O domínio do remetente precisa estar verificado no painel do provedor.
RESEND_API_KEY=""
PASSWORD_RESET_EMAIL_FROM="EcomZero <conta@ecomzero.com.br>"

# Chave que o endpoint POST /api/admin/sync-catalog exige no header
# "Authorization: Bearer <valor>". Quem chama esse endpoint é o admin do Hub
# (projeto-ecomzero-hub) — a mesma chave precisa estar configurada lá também
# (STOREFRONT_SYNC_API_KEY no .env do profittrack-backend). Sem essa var
# configurada, o endpoint recusa todo request (não derruba o app).
STOREFRONT_SYNC_API_KEY="troque-por-uma-chave-aleatoria-longa"

# Melhor Envio — cálculo de frete. Sandbox por enquanto; troque MELHOR_ENVIO_BASE_URL
# pra https://melhorenvio.com.br e o token pelo de produção quando for a hora.
# Sem essas vars configuradas, a rota /api/shipping/quote responde 503 (resto do
# site continua normal).
MELHOR_ENVIO_TOKEN="token-sandbox-do-melhor-envio"
MELHOR_ENVIO_BASE_URL="https://sandbox.melhorenvio.com.br"
# CEP de onde os pacotes saem (fixo, sem hífen ou com — a validação aceita os dois)
MELHOR_ENVIO_CEP_ORIGEM="01310-100"
# Cache/rate limit da rota ficam em Postgres (tabelas ShippingQuoteCache/
# ShippingRateLimit, ver migração) — sem env var própria, usam a mesma
# DATABASE_URL acima.

# OAuth de PRODUÇÃO do Melhor Envio. Só entram em uso quando MELHOR_ENVIO_BASE_URL
# apontar para https://melhorenvio.com.br (produção). No modo produção o access_token
# NÃO fica em env var — vive na tabela MelhorEnvioCredential e é renovado sozinho via
# refresh_token. Estas duas credenciais (client_id/secret da aplicação registrada no
# painel do Melhor Envio) são usadas só para essa renovação. Nunca commitar os valores.
MELHOR_ENVIO_CLIENT_ID=""
MELHOR_ENVIO_CLIENT_SECRET=""
MELHOR_ENVIO_AUTO_PURCHASE_ENABLED="false"

# Mercado Pago Payment Brick — chave pública exposta ao navegador apenas para
# renderizar/tokenizar o formulário. Use a chave da mesma aplicação/ambiente do
# access token. Na Vercel, configure também no ambiente Production antes do build.
NEXT_PUBLIC_MERCADOPAGO_PUBLIC_KEY=""

# Token privado usado apenas no servidor para criar e consultar pagamentos.
# Credenciais de teste e produção podem começar com APP_USR; copie o valor da
# seção correta no painel da aplicação.
MERCADOPAGO_ACCESS_TOKEN=""
# Use "test" localmente e "production" no ambiente Production da Vercel.
MERCADOPAGO_ENVIRONMENT="test"

# Assinatura secreta gerada em Suas integrações > Webhooks > Configurar
# notificações. É obrigatória para autenticar POSTs recebidos do Mercado Pago.
MERCADOPAGO_WEBHOOK_SECRET=""
