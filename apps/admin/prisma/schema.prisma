// ⚠️ SCHEMA ESPELHO — NÃO É DONO DO SCHEMA.
// Este projeto (apps/admin) compartilha o MESMO banco Postgres da loja
// (ecomzero raiz). O schema é de propriedade EXCLUSIVA do projeto raiz.
// NUNCA rode `prisma migrate` nem `prisma db push` aqui. Toda mudança de
// coluna/tabela nasce em ../../prisma/schema.prisma (raiz), é migrada LÁ, e
// aqui a gente só espelha a definição do model e roda `prisma generate`.
// Por isso NÃO existe pasta prisma/migrations neste projeto.

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum ProductKind {
  simples
  variacoes
}

enum CouponDiscountType {
  percentual
  valor_fixo
  frete_gratis
}

enum CouponAppliesTo {
  toda_loja
  categoria
  produto
}

enum BannerPosition {
  hero_slide
  home_middle
  home_bottom
}

enum AdminRole {
  owner
  staff
}

enum OrderStatus {
  draft
  aguardando_pagamento
  pago
  cancelado
}

enum OrderCancellationReason {
  customer_request
  out_of_stock
  suspected_fraud
  other
}

enum OrderCancellationStatus {
  processing
  failed
  completed
}

enum ShippingMode {
  legacy
  melhor_envio
  free_shipping_coupon
  free_shipping_threshold
  external
}

enum ShippingPayer {
  customer
  store
  external
  unknown
}

enum ShippingLabelStatus {
  not_applicable
  awaiting_payment
  awaiting_shipping_data
  awaiting_fiscal_document
  awaiting_invoice
  ready_to_purchase
  insufficient_balance
  processing
  purchased
  generated
  printed
  posted
  in_transit
  delivered
  error
  external
  canceled
}

enum ShippingLabelSource {
  automatic
  manual
  external
}

enum FiscalDocumentType {
  nota_fiscal
  declaracao_conteudo
}

enum CustomerNotificationType {
  payment_confirmed
  order_preparing
  order_in_transit
  order_delivered
}

enum ProductReviewStatus {
  pending
  approved
  rejected
}

// Espelho de ../../prisma/schema.prisma (raiz). Mantido em sincronia manual.
model Product {
  id               String      @id @default(uuid())
  slug             String      @unique
  categoria        String
  nome             String
  subtitulo        String
  descricao        String
  imagem           String
  imagens          String[]
  videos           String[]    @default([])
  caracteristicas  String[]
  linkShopee       String?
  linkMercadoLivre String?
  linkTiktokShop   String?
  linkShein        String?
  ativo            Boolean     @default(true)
  isNovidade       Boolean     @default(false)
  isPromocao       Boolean     @default(false)
  tipo             ProductKind @default(simples)
  categoryId       String?
  category         Category?   @relation(fields: [categoryId], references: [id], onDelete: SetNull)

  avaliacaoMedia  Float?
  totalAvaliacoes Int    @default(0)
  comentarios     Json?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  variantes ProductVariant[]
  reviews   ProductReview[]

  @@index([categoria])
  @@index([categoryId])
  @@index([ativo, isNovidade])
  @@index([ativo, isPromocao])
}

model Category {
  id            String     @id @default(uuid())
  nome          String
  slug          String     @unique
  descricao     String?
  imagemUrl     String?
  destaque      Boolean    @default(false)
  metaTitulo    String?
  metaDescricao String?
  parentId      String?
  parent        Category?  @relation("CategoryHierarchy", fields: [parentId], references: [id], onDelete: Restrict)
  children      Category[] @relation("CategoryHierarchy")
  ativo         Boolean    @default(true)
  ordem         Int        @default(0)
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt

  produtos Product[]

  @@index([parentId, ordem])
}

model ProductVariant {
  id         String  @id @default(uuid())
  productId  String
  product    Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  label      String
  precoDe    Decimal @db.Decimal(10, 2)
  precoPor   Decimal @db.Decimal(10, 2)
  skuInterno String? @unique
  linkShopee String?

  pesoKg        Float @default(0.3)
  alturaCm      Float @default(4)
  larguraCm     Float @default(16)
  comprimentoCm Float @default(11)

  orderItems OrderItem[]

  @@index([productId])
}

// Usuário do painel administrativo. Ver comentário no schema raiz.
model AdminUser {
  id                          String               @id @default(uuid())
  email                       String               @unique
  senhaHash                   String
  role                        AdminRole            @default(owner)
  sessionsValidAfter          DateTime?
  twoFactorEnabled            Boolean              @default(false)
  twoFactorSecretEncrypted    String?
  twoFactorRecoveryCodeHashes String?              @db.Text
  twoFactorLastUsedStep       Int?
  twoFactorEnabledAt          DateTime?
  createdAt                   DateTime             @default(now())
  updatedAt                   DateTime             @updatedAt
  loginChallenge              AdminLoginChallenge?
}

model AdminLoginChallenge {
  id          String    @id @default(uuid())
  adminUserId String    @unique
  tokenHash   String    @unique
  codeHash    String
  expiresAt   DateTime
  attempts    Int       @default(0)
  sendCount   Int       @default(1)
  lastSentAt  DateTime  @default(now())
  consumedAt  DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  adminUser   AdminUser @relation(fields: [adminUserId], references: [id], onDelete: Cascade)

  @@index([expiresAt])
  @@index([consumedAt])
}

model User {
  id              String    @id @default(uuid())
  name            String?   @map("nome")
  email           String    @unique
  emailVerified   DateTime?
  image           String?
  telefone        String?
  aceitaMarketing Boolean   @default(false)
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  notifications  Notification[]
  productReviews ProductReview[]
}

model Order {
  id                             String        @id @default(uuid())
  status                         OrderStatus   @default(draft)
  userId                         String?
  nomeCliente                    String?
  emailCliente                   String?
  telefoneCliente                String?
  cpfCnpj                        String?
  cepDestino                     String?
  logradouro                     String?
  numero                         String?
  complemento                    String?
  bairro                         String?
  cidade                         String?
  uf                             String?
  subtotal                       Decimal       @default(0) @db.Decimal(10, 2)
  valorFrete                     Decimal       @default(0) @db.Decimal(10, 2)
  descontoCupom                  Decimal       @default(0) @db.Decimal(10, 2)
  total                          Decimal       @default(0) @db.Decimal(10, 2)
  shippingQuoteId                String?       @unique
  shippingOptionId               String?
  shippingMode                   ShippingMode  @default(legacy)
  shippingProvider               String?
  shippingService                String?
  shippingAmountCharged          Decimal       @default(0) @db.Decimal(10, 2)
  shippingPayer                  ShippingPayer @default(unknown)
  shippingEstimatedDays          Int?
  mercadoPagoPreferenceId        String?       @unique
  mercadoPagoInitPoint           String?
  mercadoPagoPreferenceExpiresAt DateTime?
  mercadoPagoPaymentId           String?       @unique
  mercadoPagoPaymentStatus       String?
  pagoEm                         DateTime?
  createdAt                      DateTime      @default(now())

  items                 OrderItem[]
  shipment              Shipment?
  shippingQuote         CheckoutShippingQuote? @relation("CartShippingQuote")
  selectedShippingQuote CheckoutShippingQuote? @relation("SelectedShippingQuote", fields: [shippingQuoteId], references: [id], onDelete: SetNull)
  cancellation          OrderCancellation?
  events                OrderEvent[]
  notifications         Notification[]
  reviews               ProductReview[]

  @@index([userId])
  @@index([status, shippingMode])
}

model OrderCancellation {
  id                      String                  @id @default(uuid())
  orderId                 String                  @unique
  order                   Order                   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  reason                  OrderCancellationReason
  note                    String?
  requestedBy             String
  previousOrderStatus     OrderStatus
  status                  OrderCancellationStatus @default(processing)
  shipmentCanceled        Boolean                 @default(false)
  mercadoPagoRefundId     String?
  mercadoPagoRefundStatus String?
  attempts                Int                     @default(1)
  processingToken         String?
  processingStartedAt     DateTime?
  lastError               String?
  completedAt             DateTime?
  createdAt               DateTime                @default(now())
  updatedAt               DateTime                @updatedAt

  @@index([status, processingStartedAt])
}

model OrderEvent {
  id         String       @id @default(uuid())
  orderId    String
  order      Order        @relation(fields: [orderId], references: [id], onDelete: Cascade)
  type       String
  status     OrderStatus?
  message    String?
  actorEmail String?
  metadata   Json?
  createdAt  DateTime     @default(now())

  @@index([orderId, createdAt])
}

model Coupon {
  id                  String             @id @default(uuid())
  codigo              String             @unique
  descricao           String?
  tipo                CouponDiscountType
  valor               Decimal?           @db.Decimal(10, 2) // null quando tipo = frete_gratis
  valorMinimoPedido   Decimal?           @db.Decimal(10, 2)
  descontoMaximo      Decimal?           @db.Decimal(10, 2)
  limiteUsoTotal      Int?
  limiteUsoPorCliente Int                @default(1)
  usos                Int                @default(0)
  aplicaEm            CouponAppliesTo    @default(toda_loja)
  categoriaId         String?
  produtoId           String?
  combinavel          Boolean            @default(false)
  exibirNoSite        Boolean            @default(false)
  primeiraCompra      Boolean            @default(false)
  inicioEm            DateTime?
  expiraEm            DateTime?
  ativo               Boolean            @default(true)
  createdAt           DateTime           @default(now())
  updatedAt           DateTime           @updatedAt

  announcementItems AnnouncementBarItem[]

  @@index([ativo, inicioEm, expiraEm])
}

model Banner {
  id        String         @id @default(uuid())
  nome      String
  imagemUrl String
  altText   String
  linkUrl   String?
  posicao   BannerPosition
  largura   Int
  altura    Int
  ordem     Int            @default(0)
  ativo     Boolean        @default(true)
  inicioEm  DateTime?
  expiraEm  DateTime?
  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt

  @@index([posicao, ativo, ordem])
}

model StoreSettings {
  id                            String    @id @default("singleton")
  nomeLoja                      String    @default("EcomZero")
  descricaoFooter               String    @default("Produtos inteligentes, úteis e de qualidade para transformar sua rotina.")
  mensagemFooter                String    @default("Este site utiliza conexão segura e não armazena os dados do seu cartão.")
  barraAnuncioAtiva             Boolean   @default(false)
  barraAnuncioTexto             String?
  barraAnuncioLink              String?
  barraAnuncioCor               String?
  barraAnuncioVelocidade        Int       @default(5)
  emailSuporte                  String?
  telefoneSuporte               String?
  whatsapp                      String?
  linkShopee                    String?
  linkInstagram                 String?
  linkFacebook                  String?
  linkTiktok                    String?
  linkYoutube                   String?
  linkTwitter                   String?
  instagramAtivo                Boolean   @default(false)
  facebookAtivo                 Boolean   @default(false)
  tiktokAtivo                   Boolean   @default(false)
  youtubeAtivo                  Boolean   @default(false)
  twitterAtivo                  Boolean   @default(false)
  shopeeAtivo                   Boolean   @default(false)
  linkMercadoLivre              String?
  mercadoLivreAtivo             Boolean   @default(false)
  linkTiktokShop                String?
  tiktokShopAtivo               Boolean   @default(false)
  linkShein                     String?
  sheinAtivo                    Boolean   @default(false)
  emailSuporteAtivo             Boolean   @default(false)
  telefoneSuporteAtivo          Boolean   @default(false)
  whatsappAtivo                 Boolean   @default(false)
  whatsappMensagem              String    @default("Olá! Preciso de ajuda com a minha compra.")
  horariosAtendimento           Json?
  footerColumns                 Json?
  footerBenefits                Json?
  footerSecurityItems           Json?
  footerSeloSeguranca           Boolean   @default(true)
  footerCopyrightTexto          String    @default("Todos os direitos reservados.")
  footerCopyrightAno            String    @default("automatico")
  footerCopyrightAnoFixo        Int?
  razaoSocial                   String?
  cnpjLoja                      String?
  enderecoEmpresa               String?
  mensagemBoasVindasAtiva       Boolean   @default(false)
  mensagemBoasVindas            String    @default("Olá, {nome_cliente}! Sua conta foi criada com sucesso.")
  mensagemPedidoConfirmadoAtiva Boolean   @default(true)
  mensagemPedidoConfirmado      String    @default("O pagamento do pedido {numero_pedido} foi confirmado.")
  mensagemPedidoEnviadoAtiva    Boolean   @default(true)
  mensagemPedidoEnviado         String    @default("Seu pedido {numero_pedido} está a caminho!")
  mensagemPedidoEntregueAtiva   Boolean   @default(true)
  mensagemPedidoEntregue        String    @default("Seu pedido {numero_pedido} foi entregue!")
  metaPixelAtivo                Boolean   @default(false)
  metaPixelId                   String?
  metaCatalogFeedAtivo          Boolean   @default(true)
  metaCatalogIncludeOutOfStock  Boolean   @default(true)
  metaCatalogIncludeSalePrice   Boolean   @default(true)
  metaCatalogIncludeImages      Boolean   @default(true)
  metaCatalogDefaultBrand       String    @default("EcomZero")
  metaCatalogDefaultCategory    String    @default("")
  metaCatalogLastValidatedAt    DateTime?
  googleAnalyticsAtivo          Boolean   @default(false)
  googleAnalyticsId             String?
  googleTagManagerAtivo         Boolean   @default(false)
  googleTagManagerId            String?
  tiktokPixelAtivo              Boolean   @default(false)
  tiktokPixelId                 String?
  customHeadCodeAtivo           Boolean   @default(false)
  customHeadCode                String?
  modoManutencao                Boolean   @default(false)
  mensagemManutencao            String    @default("Estamos preparando novidades. Voltamos em breve!")
  valorMinimoPedido             Decimal   @default(0) @db.Decimal(10, 2)
  logoUrl                       String    @default("/images/logo2.png")
  faviconUrl                    String?
  corPrincipal                  String    @default("#A9EC17")
  fusoHorario                   String    @default("America/Sao_Paulo")
  lojaAtiva                     Boolean   @default(true)
  plano                         String    @default("Profissional")
  moeda                         String    @default("BRL")
  idioma                        String    @default("pt-BR")
  fontFamily                    String    @default("geist")
  productCardStyle              String    @default("standard")
  cardCornerStyle               String    @default("rounded")
  showRating                    Boolean   @default(true)
  showBuyNowButton              Boolean   @default(true)
  buttonStyle                   String    @default("filled")
  updatedAt                     DateTime  @updatedAt
}

model AnnouncementBarItem {
  id               String   @id @default(uuid())
  texto            String
  link             String?
  ordem            Int      @default(0)
  ativo            Boolean  @default(true)
  couponId         String?
  coupon           Coupon?  @relation(fields: [couponId], references: [id], onDelete: SetNull)
  // Siglas de UF elegíveis (vazio = sem restrição). Segmentação regional da barra.
  regioesElegiveis String[] @default([])
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@index([ativo, ordem])
  @@index([couponId])
}

model MelhorEnvioCredential {
  id           String   @id @default("singleton")
  accessToken  String
  refreshToken String
  expiraEm     DateTime
  atualizadoEm DateTime @updatedAt
}

model CheckoutShippingQuote {
  id              String   @id @default(uuid())
  orderId         String   @unique
  order           Order    @relation("CartShippingQuote", fields: [orderId], references: [id], onDelete: Cascade)
  selectedByOrder Order?   @relation("SelectedShippingQuote")
  cep             String
  options         Json
  createdAt       DateTime @default(now())
  expiresAt       DateTime

  @@index([expiresAt])
}

model OrderItem {
  id            String         @id @default(uuid())
  orderId       String
  order         Order          @relation(fields: [orderId], references: [id], onDelete: Cascade)
  variantId     String
  variant       ProductVariant @relation(fields: [variantId], references: [id])
  quantidade    Int
  precoUnitario Decimal        @db.Decimal(10, 2)
  review        ProductReview?

  @@unique([orderId, variantId])
  @@index([orderId])
  @@index([variantId])
}

model ProductReview {
  id              String              @id @default(uuid())
  userId          String
  user            User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  productId       String
  product         Product             @relation(fields: [productId], references: [id], onDelete: Cascade)
  orderId         String
  order           Order               @relation(fields: [orderId], references: [id], onDelete: Cascade)
  orderItemId     String              @unique
  orderItem       OrderItem           @relation(fields: [orderItemId], references: [id], onDelete: Cascade)
  rating          Int
  comment         String?
  photos          String[]            @default([])
  status          ProductReviewStatus @default(pending)
  moderatedAt     DateTime?
  moderatedBy     String?
  rejectionReason String?
  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt

  @@index([productId, status])
  @@index([userId, createdAt])
  @@index([status, createdAt])
}

model ShippingSettings {
  id                    String             @id @default("singleton")
  nomeRemetente         String
  emailRemetente        String
  telefoneRemetente     String
  cpfCnpjRemetente      String
  inscricaoEstadual     String?
  atividadeEconomica    String?
  cepOrigem             String
  logradouroOrigem      String
  numeroOrigem          String
  complementoOrigem     String?
  bairroOrigem          String
  cidadeOrigem          String
  ufOrigem              String
  documentoFiscalPadrao FiscalDocumentType @default(declaracao_conteudo)
  updatedAt             DateTime           @updatedAt
}

model Shipment {
  id                              String               @id @default(uuid())
  orderId                         String               @unique
  order                           Order                @relation(fields: [orderId], references: [id], onDelete: Cascade)
  melhorEnvioId                   String?              @unique
  melhorEnvioProtocol             String?
  status                          String               @default("creating")
  labelStatus                     ShippingLabelStatus  @default(awaiting_shipping_data)
  labelSource                     ShippingLabelSource?
  serviceId                       String?
  transportadora                  String?
  servico                         String?
  prazoDias                       Int?
  custoEstimado                   Decimal?             @db.Decimal(10, 2)
  custoEtiqueta                   Decimal?             @db.Decimal(10, 2)
  codigoRastreio                  String?
  urlRastreio                     String?
  urlEtiqueta                     String?
  referenciaEtiqueta              String?
  tipoDocumentoFiscal             FiscalDocumentType?
  tipoDocumentoFiscalConfirmadoEm DateTime?
  chaveNotaFiscal                 String?
  ultimoErro                      String?
  ultimoErroCodigo                String?
  tentativas                      Int                  @default(0)
  processandoEm                   DateTime?
  processamentoToken              String?
  ultimaTentativaEm               DateTime?
  saldoConsultadoEm               DateTime?
  compradoEm                      DateTime?
  geradoEm                        DateTime?
  impressoEm                      DateTime?
  postadoEm                       DateTime?
  entregueEm                      DateTime?
  canceladoEm                     DateTime?
  createdAt                       DateTime             @default(now())
  updatedAt                       DateTime             @updatedAt

  events ShipmentEvent[]

  @@index([status])
  @@index([labelStatus])
  @@index([processandoEm])
}

model ShipmentEvent {
  id         String               @id @default(uuid())
  shipmentId String
  shipment   Shipment             @relation(fields: [shipmentId], references: [id], onDelete: Cascade)
  type       String
  status     ShippingLabelStatus?
  message    String?
  metadata   Json?
  createdAt  DateTime             @default(now())

  @@index([shipmentId, createdAt])
}

model Notification {
  id        String                   @id @default(uuid())
  userId    String
  user      User                     @relation(fields: [userId], references: [id], onDelete: Cascade)
  orderId   String
  order     Order                    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  type      CustomerNotificationType
  title     String
  message   String
  lida      Boolean                  @default(false)
  lidaEm    DateTime?
  createdAt DateTime                 @default(now())

  @@unique([userId, orderId, type])
  @@index([userId, lida, createdAt])
  @@index([orderId])
}

model MelhorEnvioBalanceCache {
  id           String    @id @default("singleton")
  saldo        Decimal?  @db.Decimal(12, 2)
  disponivel   Boolean   @default(false)
  consultadoEm DateTime?
  ultimoErro   String?
  updatedAt    DateTime  @updatedAt
}

// Espelho de ../../prisma/schema.prisma (dono). Migração nasce na raiz.
model AuthRateLimit {
  id          String   @id @default(uuid())
  identifier  String   @unique // "escopo:ip" ou "escopo:email"
  count       Int      @default(1)
  windowStart DateTime @default(now())

  @@index([windowStart])
}
